// Physics Error Bank — PostgreSQL (Prisma 6)
// Apply schema: npm run db:migrate   (needs DATABASE_URL in .env)
// Client:       npm run db:generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
}

enum PaperSession {
  MAY
  NOV
}

enum ChoiceOption {
  A
  B
  C
  D
  BLANK
}

/// Registered student accounts (source of truth for auth).
model User {
  id                    String    @id @default(uuid()) @db.Uuid
  email                 String    @unique
  passwordHash          String    @map("password_hash")
  /// Hashed with the same scrypt format as passwords; used for forgot-password flow.
  recoveryAnswer1Hash   String?   @map("recovery_answer_1_hash")
  recoveryAnswer2Hash   String?   @map("recovery_answer_2_hash")
  recoveryAnswer3Hash   String?   @map("recovery_answer_3_hash")
  name                  String    @default("") @db.VarChar(80)
  role                  UserRole  @default(STUDENT)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  mistakes              Mistake[]
  tags                  Tag[]
  paperAttempts         PaperAttempt[]
  papersCreated         Paper[]   @relation("PaperCreator")

  @@map("users")
}

model TeacherEmailAllowlist {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(320)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("teacher_email_allowlist")
}

/// One saved mistake per user. Store the image in object storage; `imageKey` is the bucket key (or public URL path).
model Mistake {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes       String       @default("")
  imageKey    String       @map("image_key") @db.VarChar(1024)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  mistakeTags MistakeTag[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("mistakes")
}

/// Tags are scoped per user (same label can exist for different users).
model Tag {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String       @db.VarChar(128)
  mistakeTags MistakeTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model MistakeTag {
  mistakeId String  @map("mistake_id") @db.Uuid
  tagId     String  @map("tag_id") @db.Uuid
  mistake   Mistake @relation(fields: [mistakeId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mistakeId, tagId])
  @@index([tagId])
  @@map("mistake_tags")
}

model Paper {
  id            String        @id @default(uuid()) @db.Uuid
  title         String        @db.VarChar(160)
  year          Int
  session       PaperSession
  questionCount Int           @default(40) @map("question_count")
  dp1AtoCOnly   Boolean       @default(false) @map("dp1_a_to_c_only")
  publishedAt   DateTime?     @map("published_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdById   String        @map("created_by_id") @db.Uuid
  createdBy     User          @relation("PaperCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questions     PaperQuestion[]
  attempts      PaperAttempt[]

  @@unique([title])
  @@index([year, session])
  @@index([publishedAt])
  @@index([createdAt(sort: Desc)])
  @@map("papers")
}

model PaperQuestion {
  id            String       @id @default(uuid()) @db.Uuid
  paperId       String       @map("paper_id") @db.Uuid
  number        Int
  correctAnswer ChoiceOption @map("correct_answer")
  /// IB syllabus theme (Theme A–E or Theme M), not sub-topic tags.
  theme         String       @default("") @db.VarChar(200)
  paper         Paper        @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([paperId, number])
  @@index([paperId])
  @@map("paper_questions")
}

model PaperAttempt {
  id           String               @id @default(uuid()) @db.Uuid
  paperId      String               @map("paper_id") @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  submittedAt  DateTime             @default(now()) @map("submitted_at")
  correctCount Int                  @default(0) @map("correct_count")
  wrongCount   Int                  @default(0) @map("wrong_count")
  accuracy     Decimal              @default(0) @db.Decimal(5, 2)
  isLatest     Boolean              @default(true) @map("is_latest")
  paper        Paper                @relation(fields: [paperId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers      PaperAttemptAnswer[]

  @@index([paperId, userId, submittedAt(sort: Desc)])
  @@index([paperId, isLatest])
  @@index([userId, submittedAt(sort: Desc)])
  @@map("paper_attempts")
}

model PaperAttemptAnswer {
  id             String       @id @default(uuid()) @db.Uuid
  attemptId      String       @map("attempt_id") @db.Uuid
  questionNumber Int          @map("question_number")
  studentAnswer  ChoiceOption @map("student_answer")
  correctAnswer  ChoiceOption @map("correct_answer")
  isCorrect      Boolean      @map("is_correct")
  themeSnapshot  String       @default("") @map("theme_snapshot") @db.VarChar(200)
  attempt        PaperAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionNumber])
  @@index([attemptId])
  @@index([isCorrect])
  @@map("paper_attempt_answers")
}
